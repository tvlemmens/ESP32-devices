# Standaard ESP en HA instellingen 
substitutions:
  devicename: 213-e-paper
  friendly_name: 2.13 e-Paper
  static_ip: 10.0.0.63

# Basis configuratie
esphome:
  name: ${devicename}
esp32:
  board: esp32dev
  framework:
    type: esp-idf

# Load ESP32 device defaults via common base file
packages:   # as a list
  - !include common/base.yaml

# Enable OTA updates
ota:
  platform: esphome


# Home Assistant sensors
sensor:
  - platform: homeassistant
    id: living_temperature
    entity_id: sensor.diyless_thermostat_ble_sensor_temperature
    on_value: 
      then:
        - lvgl.label.update: 
            id: lv_label_temp
            text:
              format: "%.1f °C"
              args: [ 'id(living_temperature).get_state()' ]
        - component.update: epd

  - platform: homeassistant
    id: living_humidity
    entity_id: sensor.diyless_thermostat_ble_humidity
    on_value: 
      then:
        - lvgl.label.update: 
            id: lv_label_hum
            text:
              format: "%.1f °C"
              args: [ 'id(living_humidity).get_state()' ]


wifi:
  id: wifi_id
  
### DISPLAY SECTION ###

### CONNECTORS
# VCC   3v3
# GND   gnd
# DIN   15    = SPI mosi pin (spi.mosi_pin)
# CLK   16    = SPI clock pin (spi.clk_pin)
# CS    17
# DC    18
# RST   19
# BUSY  21

# Example configuration entry - single controller
spi:
  clk_pin: 16
  mosi_pin: 15

display:
  - platform: waveshare_epaper
    id: epd
    cs_pin: 17
    dc_pin: 18
    busy_pin: 21
    reset_pin: 19
    model: 2.13inv3
    # update_interval: 5min
    full_update_every: 30
    rotation: 90


lvgl:
  buffer_size: 25%

  pages:
    - id: canvas_1
      bg_color: 0x000000
      widgets:
