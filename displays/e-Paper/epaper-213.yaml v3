            id: lv_label_date
            x: 0
            y: 0
            width: 170
            height: 25
            text: "Mon 01 Mar 2026"
            text_color: 0xFFFFFF
            text_font: montserrat_18

        - label:
            id: lv_label_updated
            x: 175
            y: 1
            width: 71
            height: 10
            text: "Last update"
